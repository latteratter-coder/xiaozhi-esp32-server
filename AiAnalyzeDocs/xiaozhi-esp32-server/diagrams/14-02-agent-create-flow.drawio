                <mxCell id="lane-ctrl" value="AgentController" style="shape=table;startSize=30;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;horizontal=0;" vertex="1" parent="1">
