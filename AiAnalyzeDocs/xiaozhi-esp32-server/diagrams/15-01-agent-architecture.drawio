                <!-- Action 判断 -->
                <mxCell id="action-check" value="Action?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="agent-core">
                    <mxGeometry x="310" y="200" width="110" height="50" as="geometry"/>
                </mxCell>

                <!-- REQLLM -->
                <mxCell id="reqllm" value="REQLLM&#xa;结果写入对话&#xa;(role=tool)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="agent-core">
                    <mxGeometry x="480" y="195" width="130" height="55" as="geometry"/>
                </mxCell>

                <!-- 递归 -->
                <mxCell id="recurse" value="递归 chat(None, depth+1)&#xa;★ Agent 循环的核心 ★" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=5;strokeWidth=2;" vertex="1" parent="agent-core">
