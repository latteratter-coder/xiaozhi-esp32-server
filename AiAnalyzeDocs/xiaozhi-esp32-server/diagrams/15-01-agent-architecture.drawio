<mxfile host="65bd71144e">
    <diagram id="agent-arch" name="xiaozhi-server Agent 架构">
        <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- 标题 -->
                <mxCell id="title" value="xiaozhi-server Agent 完整架构" style="text;html=1;fontSize=20;fontStyle=1;fillColor=none;align=center;" vertex="1" parent="1">
                    <mxGeometry x="500" y="10" width="500" height="30" as="geometry"/>
                </mxCell>

                <!-- ===== 设备层 ===== -->
                <mxCell id="device" value="ESP32 设备" style="shape=mxgraph.cisco.computers_and_peripherals.pc;html=1;fillColor=#036897;strokeColor=#ffffff;fontSize=12;fontColor=#333333;fontStyle=1;labelPosition=center;verticalLabelPosition=bottom;align=center;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="60" y="80" width="60" height="50" as="geometry"/>
                </mxCell>

                <!-- ===== WebSocket 层 ===== -->
                <mxCell id="ws-box" value="WebSocket Server (Port 8000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="200" y="80" width="230" height="40" as="geometry"/>
                </mxCell>

                <!-- ===== 语音处理流水线 ===== -->
                <mxCell id="pipeline" value="语音处理流水线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=13;container=1;collapsible=0;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="200" y="150" width="800" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="vad" value="VAD&#xa;语音活动检测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pipeline">
                    <mxGeometry x="10" y="35" width="100" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="asr" value="ASR&#xa;语音识别→文字" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pipeline">
                    <mxGeometry x="130" y="35" width="110" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="intent" value="意图判断&#xa;nointent / function_call&#xa;/ intent_llm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="pipeline">
                    <mxGeometry x="260" y="35" width="140" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="tts-box" value="TTS&#xa;文字→语音" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pipeline">
                    <mxGeometry x="580" y="35" width="100" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="opus" value="Opus 编码&#xa;→ 回传设备" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pipeline">
                    <mxGeometry x="695" y="35" width="95" height="45" as="geometry"/>
                </mxCell>

                <mxCell id="pe1" style="rounded=1;" edge="1" source="vad" target="asr" parent="pipeline"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="pe2" style="rounded=1;" edge="1" source="asr" target="intent" parent="pipeline"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="pe5" style="rounded=1;" edge="1" source="tts-box" target="opus" parent="pipeline"><mxGeometry relative="1" as="geometry"/></mxCell>

                <!-- ===== Agent 核心（chat 递归） ===== -->
                <mxCell id="agent-core" value="Agent 核心：chat(query, depth) 递归循环" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=14;container=1;collapsible=0;spacingTop=5;" vertex="1" parent="1">
                    <mxGeometry x="200" y="280" width="800" height="340" as="geometry"/>
                </mxCell>

                <!-- 对话管理 -->
                <mxCell id="dialogue" value="Dialogue 对话管理&#xa;(系统提示词 + 历史消息 + 记忆)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="agent-core">
                    <mxGeometry x="10" y="40" width="220" height="45" as="geometry"/>
                </mxCell>

                <!-- LLM 调用 -->
                <mxCell id="llm-call" value="LLM 流式调用&#xa;response_with_functions()&#xa;（带工具描述）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="agent-core">
                    <mxGeometry x="270" y="35" width="200" height="55" as="geometry"/>
                </mxCell>

                <!-- CoT 过滤 -->
                <mxCell id="cot-filter" value="CoT 过滤&#xa;遇 &lt;think&gt; 暂停输出&#xa;遇 &lt;/think&gt; 恢复输出&#xa;（兼容 DeepSeek-R1 等）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="agent-core">
                    <mxGeometry x="510" y="30" width="160" height="65" as="geometry"/>
                </mxCell>

                <!-- LLM 决策分支 -->
                <mxCell id="decision" value="LLM 自主决策" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="agent-core">
                    <mxGeometry x="310" y="120" width="130" height="60" as="geometry"/>
                </mxCell>

                <!-- 分支1: 纯文本 -->
                <mxCell id="text-out" value="纯文本回答&#xa;逐 token → TTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="agent-core">
                    <mxGeometry x="530" y="120" width="120" height="45" as="geometry"/>
                </mxCell>

                <!-- 分支2: tool_calls -->
                <mxCell id="tool-calls" value="返回 tool_calls&#xa;（工具名 + 参数）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="agent-core">
