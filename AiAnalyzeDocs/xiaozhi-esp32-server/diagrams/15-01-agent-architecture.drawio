                <mxCell id="ae5" value="tool_calls" style="rounded=1;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" edge="1" source="decision" target="tool-calls" parent="agent-core"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="ae6" style="rounded=1;" edge="1" source="tool-calls" target="tool-exec" parent="agent-core"><mxGeometry relative="1" as="geometry"/></mxCell>
