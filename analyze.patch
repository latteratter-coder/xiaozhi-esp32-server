+### 4.5 SysUserTokenServiceImpl — Token 生成与存储
+
+```java
+// modules/security/service/impl/SysUserTokenServiceImpl.java
+
+@Service
+public class SysUserTokenServiceImpl extends BaseServiceImpl<SysUserTokenDao, SysUserTokenEntity>
+        implements SysUserTokenService {
+
+    private final static int EXPIRE = 3600 * 12;  // Token 有效期：12小时
+
+    @Override
+    public Result<TokenDTO> createToken(Long userId) {
+        String token;
+        Date now = new Date();
+        Date expireTime = new Date(now.getTime() + EXPIRE * 1000);
+
+        // 查询该用户是否已有 Token 记录
+        SysUserTokenEntity tokenEntity = baseDao.getByUserId(userId);
+
+        if (tokenEntity == null) {
+            // 首次登录：生成新 Token，INSERT 入表
+            token = TokenGenerator.generateValue();
+
+            tokenEntity = new SysUserTokenEntity();
+            tokenEntity.setUserId(userId);
+            tokenEntity.setToken(token);
+            tokenEntity.setUpdateDate(now);
+            tokenEntity.setExpireDate(expireTime);
+            this.insert(tokenEntity);
+
+        } else {
+            // 非首次登录
+            if (tokenEntity.getExpireDate().getTime() < System.currentTimeMillis()) {
+                // Token 已过期 → 重新生成
+                token = TokenGenerator.generateValue();
+            } else {
+                // Token 未过期 → 沿用旧 Token
+                token = tokenEntity.getToken();
+            }
+            // 更新过期时间（续期）
+            tokenEntity.setToken(token);
+            tokenEntity.setUpdateDate(now);
+            tokenEntity.setExpireDate(expireTime);
+            this.updateById(tokenEntity);
+        }
+
+        // 构造返回给前端的 TokenDTO
+        TokenDTO tokenDTO = new TokenDTO();
+        tokenDTO.setToken(token);
+        tokenDTO.setExpire(EXPIRE);
+        tokenDTO.setClientHash(HttpContextUtils.getClientCode());
+        return new Result<TokenDTO>().ok(tokenDTO);
+    }
+}
+```
+
+**Token 签发策略流程图：**
+```
+查 sys_user_token 表（按 userId）
+  │
+  ├── 不存在 → 生成新 Token → INSERT
+  │
+  └── 存在
+        ├── 已过期 → 生成新 Token → UPDATE
+        └── 未过期 → 沿用旧 Token → UPDATE（续期 12 小时）
+```
+
+### 4.6 TokenGenerator — Token 值生成算法
+
+```java
+// modules/security/oauth2/TokenGenerator.java
+
+public class TokenGenerator {
+
+    public static String generateValue() {
+        return generateValue(UUID.randomUUID().toString());
+    }
+
+    public static String generateValue(String param) {
+        // UUID → MD5 → 32 位十六进制字符串
+        MessageDigest algorithm = MessageDigest.getInstance("MD5");
+        algorithm.reset();
+        algorithm.update(param.getBytes());
+        byte[] messageDigest = algorithm.digest();
+        return toHexString(messageDigest);
+    }
+
+    // 示例输出："e10adc3949ba59abbe56e057f20f883e"
+}
+```
