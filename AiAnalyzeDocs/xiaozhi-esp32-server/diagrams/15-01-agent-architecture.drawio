                <!-- MAX_DEPTH -->
                <mxCell id="max-depth" value="depth ≥ 5&#xa;注入[系统提示]&#xa;强制最终回答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;fontStyle=2;" vertex="1" parent="agent-core">
